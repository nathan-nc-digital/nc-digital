---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLD from '../components/JsonLD.astro';
import { Image } from 'astro:assets';
import nathanImg from '../assets/nathan.webp';
import { createReader } from '@keystatic/core/reader';
import config from '../../keystatic.config';
import { getCollection } from 'astro:content';

const reader = createReader(process.cwd(), config);
const settings = await reader.singletons.siteSettings.read();
const portfolioEntries = await getCollection('portfolio');

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/portfolio/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
function getPortfolioImage(slug: string) {
  for (const [path, mod] of Object.entries(portfolioImages)) {
    const filename = path.split('/').pop()!.replace(/\.[^.]+$/, '');
    if (filename === slug) return mod.default;
  }
  return null;
}

const blogEntries = (await reader.collections.blog.all())
  .sort((a, b) => {
    const dateA = a.entry.pubDate ? new Date(a.entry.pubDate).getTime() : 0;
    const dateB = b.entry.pubDate ? new Date(b.entry.pubDate).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);

const stats = [
  { value: '10+', label: 'Years of Experience' },
  { value: '50+', label: 'Websites Built' },
  { value: '100%', label: 'Custom Built' },
  { value: '5★', label: 'Google Rating' },
];

const services = [
  {
    num: '01',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: 'Website Design & Build',
    desc: 'Custom, mobile-optimised websites crafted to help your business stand out, convert visitors, and grow online.',
    href: '/services/web-development',
  },
  {
    num: '02',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Website Hosting & Security',
    desc: 'Fast, UK-based web hosting with free SSL certificates, daily backups, and security monitoring — keeping your site safe and running.',
    href: '/services/website-hosting-security',
  },
  {
    num: '03',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Website Maintenance Packages',
    desc: 'Ongoing support to keep your site updated, secure, and growing — including regular updates, backups, and small edits.',
    href: '/services/website-maintenance-packages',
  },
  {
    num: '04',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: 'Local SEO & Google Ranking',
    desc: 'SEO foundations built into your site, plus targeted strategies to help you appear higher in local search results and maps.',
    href: '/services/local-seo-google-ranking',
  },
  {
    num: '05',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>`,
    title: 'Professional Mailboxes & Email Setup',
    desc: 'Reliable business email using your own domain, so you look professional and stay organised. We\'ll set everything up, keep it secure, and help manage accounts as your team grows.',
    href: '/services/professional-mailboxes-email-setup',
  },
];
---

<BaseLayout
  title="NC Digital — Web Design & SEO South Wales"
  description={settings?.heroSubtext ?? 'Affordable web design and local SEO for South Wales small businesses.'}
>

  <JsonLD schema={{
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "NC Digital",
    "description": "Web design and local SEO for South Wales small businesses.",
    "url": "https://nc-digital.co.uk",
    "email": "nathan@nc-digital.co.uk",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Merthyr Tydfil",
      "addressRegion": "South Wales",
      "addressCountry": "GB"
    },
    "areaServed": {
      "@type": "State",
      "name": "South Wales"
    },
    "serviceType": ["Web Design", "Local SEO", "Website Maintenance"]
  }} />

  <!-- HERO -->
  <section style="padding:5rem 0 4rem; position:relative; overflow:hidden;">
    <div style="position:absolute; top:-100px; right:0; width:600px; height:600px; background:radial-gradient(circle, #8750f720 0%, transparent 70%); pointer-events:none;"></div>

    <div class="container site-pad layout-hero">

      <div>
        <p data-animate="fade-up" class="eyebrow" style="margin-bottom:1rem;">Web Design · SEO · South Wales</p>
        <h1 data-animate="fade-up" style="margin-bottom:1.25rem;">
          {settings?.heroHeadline ?? 'Websites that rank. Businesses that grow.'}
        </h1>
        <p data-animate="fade-up" style="color:var(--text-muted); font-size:1.125rem; line-height:1.7; margin-bottom:2rem; max-width:480px;">
          {settings?.heroSubtext ?? 'Affordable web design and local SEO for South Wales small businesses.'}
        </p>
        <div data-animate="fade-up" style="display:flex; gap:1rem; flex-wrap:wrap;">
          <a href="/free-website-plan" class="btn-primary">
            {settings?.heroCTAPrimary ?? 'Get your free plan'} →
          </a>
          <a href="/portfolio" class="btn-outline">
            {settings?.heroCTASecondary ?? 'See our work'}
          </a>
        </div>
      </div>

      <div style="position:relative; display:flex; justify-content:center;">
        <div style="position:absolute; inset:0; background:radial-gradient(circle at center, #8750f730 0%, transparent 70%); border-radius:50%; pointer-events:none;"></div>
        <Image
          src={nathanImg}
          alt="Nathan Constance — NC Digital"
          width={380}
          data-animate="fade-in"
          class="nathan-photo"
          style="border-radius:16px; border:1px solid var(--border); display:block; max-width:100%; height:auto; position:relative;"
        />
      </div>

    </div>
  </section>

  <!-- STATS BAR -->
  <section style="border-top:1px solid var(--border); border-bottom:1px solid var(--border); padding:2rem 0; background:var(--bg-2);">
    <div class="container site-pad layout-stats">
      {stats.map(({ value, label }) => (
        <div style="text-align:center;">
          <div data-animate="counter" style="font-size:1.75rem; font-weight:800; color:var(--purple);">{value}</div>
          <div style="font-size:0.875rem; color:var(--text-muted); margin-top:0.25rem;">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" style="padding:5rem 0;">
    <div class="container site-pad">
      <div style="text-align:center; margin-bottom:3.5rem;">
        <p class="eyebrow" style="margin-bottom:0.75rem;">What we do</p>
        <h2 data-animate="fade-up" style="max-width:520px; margin:0 auto 1rem;">Everything your business needs to grow online</h2>
        <p data-animate="fade-up" style="color:var(--text-muted); font-size:1.0625rem; max-width:480px; margin:0 auto; line-height:1.7;">
          One agency, every service. No juggling multiple suppliers.
        </p>
      </div>

      <div data-animate="stagger" class="services-list">
        {services.map(({ num, icon, title, desc, href }) => (
          <a href={href} class="svc-row">
            <div class="svc-left">
              <span class="svc-num">{num}</span>
              <div class="svc-icon" set:html={icon} />
              <div>
                <h3 class="svc-title">{title}</h3>
                <p class="svc-desc">{desc}</p>
              </div>
            </div>
            <div class="svc-arrow">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section id="work" style="padding:5rem 0; background:var(--bg-2);">
    <div class="container site-pad">
      <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:3rem;">
        <div data-animate="fade-up">
          <p class="eyebrow" style="margin-bottom:0.75rem;">Our work</p>
          <h2 style="margin:0;">Recent projects</h2>
        </div>
        <a href="/portfolio" class="btn-outline" style="font-size:0.875rem;">View all →</a>
      </div>

      {portfolioEntries.length > 0 ? (
        <div data-animate="stagger" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.25rem;">
          {portfolioEntries.slice(0, 3).map((project) => {
            const slug = project.id.replace('/index.mdoc', '');
            const img = getPortfolioImage(slug);
            return (
              <a href={`/portfolio/${slug}`} class="card" style="display:block; text-decoration:none; padding:0; overflow:hidden;">
                {img ? (
                  <Image
                    src={img}
                    alt={project.data.title}
                    width={600}
                    height={340}
                    style="width:100%; height:180px; object-fit:cover; display:block;"
                  />
                ) : (
                  <div style="width:100%; height:180px; background:var(--bg-3); display:flex; align-items:center; justify-content:center;">
                    <span style="color:var(--text-muted); font-size:0.875rem;">{project.data.title}</span>
                  </div>
                )}
                <div style="padding:1.25rem;">
                  <h3 style="font-size:1rem; font-weight:600; color:var(--white); margin-bottom:0.5rem;">{project.data.client}</h3>
                  <p style="font-size:0.875rem; color:var(--text-muted); margin:0;">{project.data.summary}</p>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <p style="color:var(--text-muted);">Portfolio entries coming soon.</p>
      )}
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section style="padding:5rem 0;">
    <div class="container site-pad">
      <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:3rem;">
        <div data-animate="fade-up">
          <p class="eyebrow" style="margin-bottom:0.75rem;">Insights</p>
          <h2 style="margin:0;">Latest from the blog</h2>
        </div>
        <a href="/blog" class="btn-outline" style="font-size:0.875rem;">All posts →</a>
      </div>

      {blogEntries.length > 0 ? (
        <div data-animate="stagger" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.25rem;">
          {blogEntries.map(({ slug, entry }) => (
            <a href={`/blog/${slug}`} class="card" style="display:block; text-decoration:none;">
              <div style="background:var(--bg-3); border-radius:6px; height:160px; margin-bottom:1rem;"></div>
              <p style="font-size:0.75rem; color:var(--purple); font-weight:600; margin-bottom:0.5rem; text-transform:uppercase; letter-spacing:0.1em;">{entry.category}</p>
              <h3 style="font-size:1rem; font-weight:600; color:var(--white); margin-bottom:0.5rem; line-height:1.4;">{entry.title}</h3>
              <p style="font-size:0.875rem; color:var(--text-muted); margin:0;">{entry.description}</p>
            </a>
          ))}
        </div>
      ) : (
        <p style="color:var(--text-muted);">Blog posts coming soon.</p>
      )}
    </div>
  </section>

  <!-- CTA BANNER -->
  <section style="padding:5rem 0; background:var(--bg-2); border-top:1px solid var(--border);">
    <div class="container site-pad" style="text-align:center;">
      <p class="eyebrow" style="margin-bottom:1rem;">Ready to grow?</p>
      <h2 data-animate="fade-up" style="margin-bottom:1rem;">Let's build your online presence</h2>
      <p data-animate="fade-up" style="color:var(--text-muted); font-size:1.125rem; margin-bottom:2rem; max-width:500px; margin-left:auto; margin-right:auto;">
        Get a free website plan with no commitment. We'll show you exactly what we'd build and what it would cost.
      </p>
      <a data-animate="fade-up" href="/free-website-plan" class="btn-primary" style="font-size:1rem; padding:1rem 2rem;">
        Get your free plan →
      </a>
    </div>
  </section>

<style>
  /* Nathan photo hover */
  .nathan-photo {
    transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
    cursor: default;
  }
  .nathan-photo:hover {
    transform: rotate(2deg) scale(1.02);
    border-color: var(--purple) !important;
    box-shadow: 0 0 32px rgba(135, 80, 247, 0.35), 0 0 8px rgba(135, 80, 247, 0.2);
  }

  /* Services list */
  .services-list {
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .svc-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.75rem 2rem;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .svc-row:last-child { border-bottom: none; }

  /* animated gradient layer */
  .svc-row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(135, 80, 247, 0.13) 0%, rgba(135, 80, 247, 0.04) 55%, transparent 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }
  .svc-row:first-child::before { opacity: 1; }
  .services-list:hover .svc-row:first-child:not(:hover)::before { opacity: 0; }
  .svc-row:hover::before { opacity: 1; }

  /* icon box */
  .svc-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }
  .svc-num {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--purple);
    opacity: 0.5;
    flex-shrink: 0;
    width: 1.75rem;
    transition: opacity 0.3s ease;
  }
  .svc-row:first-child .svc-num,
  .svc-row:hover .svc-num { opacity: 1; }
  .services-list:hover .svc-row:first-child:not(:hover) .svc-num { opacity: 0.5; }
  .svc-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(135, 80, 247, 0.08);
    border: 1px solid rgba(135, 80, 247, 0.18);
    border-radius: 12px;
    color: var(--purple);
    transition: background 0.35s ease, border-color 0.35s ease, transform 0.35s ease;
  }
  .svc-row:first-child .svc-icon,
  .svc-row:hover .svc-icon {
    background: rgba(135, 80, 247, 0.16);
    border-color: rgba(135, 80, 247, 0.4);
  }
  .services-list:hover .svc-row:first-child:not(:hover) .svc-icon {
    background: rgba(135, 80, 247, 0.08);
    border-color: rgba(135, 80, 247, 0.18);
  }
  .svc-row:hover .svc-icon { transform: scale(1.08); }

  .svc-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--white);
    margin: 0 0 0.3rem;
    transition: color 0.25s ease;
  }
  .svc-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    max-width: 680px;
  }

  /* arrow */
  .svc-arrow {
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    color: var(--purple);
    opacity: 0.35;
    transition: transform 0.28s ease, opacity 0.28s ease;
  }
  .svc-row:first-child .svc-arrow { opacity: 0.75; }
  .services-list:hover .svc-row:first-child:not(:hover) .svc-arrow { opacity: 0.35; }
  .svc-row:hover .svc-arrow {
    transform: translateX(7px);
    opacity: 1;
  }
</style>

</BaseLayout>
