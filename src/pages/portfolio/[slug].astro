---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroOrbs from '../../components/HeroOrbs.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects.map((project) => ({
    params: { slug: project.id.replace('/index.mdoc', '') },
    props: { project },
  }));
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect('/portfolio');
}

const { Content } = await render(project);

const slug = project.id.replace('/index.mdoc', '');

const imageFiles = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/portfolio/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

let heroImage: ImageMetadata | null = null;
for (const [path, mod] of Object.entries(imageFiles)) {
  const filename = path.split('/').pop()!.replace(/\.[^.]+$/, '');
  if (filename === slug) {
    heroImage = mod.default;
    break;
  }
}
---

<BaseLayout
  title={project.data.metaTitle || `${project.data.title} | NC Digital Portfolio`}
  description={project.data.metaDescription || project.data.summary}
>

  <section style="padding:4rem 0 3rem; position:relative; overflow:hidden;">
    <HeroOrbs />
    <div class="container site-pad" style="position:relative; z-index:1;">
      <a href="/portfolio" style="color:var(--text-muted); font-size:0.875rem; display:inline-flex; align-items:center; gap:0.375rem; margin-bottom:2rem;">
        ← All case studies
      </a>
      <div style="text-align:center;">
        <p data-animate="fade-up" class="eyebrow" style="margin-bottom:0.75rem;">Case study</p>
        <h1 data-animate="fade-up" style="margin-bottom:1rem; max-width:640px; margin-left:auto; margin-right:auto;">{project.data.title}</h1>
        <p data-animate="fade-up" style="color:var(--text-muted); font-size:1.125rem; max-width:560px; line-height:1.7; margin:0 auto 2rem;">
          {project.data.summary}
        </p>
        <a data-animate="fade-up" href="/contact" class="btn-primary">Start your project →</a>
      </div>
    </div>
  </section>

  {heroImage && (
    <section style="padding:0 0 3rem;">
      <div class="container site-pad">
        <Image
          src={heroImage}
          alt={project.data.title}
          width={1200}
          height={600}
          style="width:100%; height:auto; max-height:500px; object-fit:cover; border-radius:12px; border:1px solid var(--border);"
        />
      </div>
    </section>
  )}

  <section style="padding:3rem 0 5rem;">
    <div class="container site-pad layout-sidebar">

      <div data-animate="fade-up" style="color:var(--text); line-height:1.8; font-size:1rem;">
        <Content />
      </div>

      <aside>
        <div data-animate="fade-in" class="card">
          <h3 style="font-size:1rem; font-weight:700; color:var(--white); margin-bottom:1rem;">Project details</h3>
          <dl style="margin:0; display:flex; flex-direction:column; gap:0.75rem;">
            <div>
              <dt style="font-size:0.8125rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.25rem;">Client</dt>
              <dd style="font-size:0.9375rem; color:var(--white); margin:0;">{project.data.client}</dd>
            </div>
            <div>
              <dt style="font-size:0.8125rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.25rem;">Services</dt>
              <dd style="margin:0; display:flex; flex-wrap:wrap; gap:0.375rem;">
                {project.data.services.map((s: string) => (
                  <span style="font-size:0.8125rem; color:var(--purple); background:var(--bg-2); border:1px solid var(--border); border-radius:4px; padding:0.2rem 0.6rem;">
                    {s}
                  </span>
                ))}
              </dd>
            </div>
          </dl>
          <div style="margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);">
            <a href="/free-website-plan" class="btn-primary" style="width:100%; justify-content:center;">Get a free plan →</a>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
