---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroOrbs from '../../components/HeroOrbs.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const projects = await getCollection('portfolio');

const subfolderImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/portfolio/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG}',
  { eager: true }
);

const fallbackImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/portfolio/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const folderMap: Record<string, string> = {
  '3d-framing':                  '3D Framing',
  'ak-promotions':               'AK Promotions',
  'creative-redevelopments':     'Creative Redevelopment',
  'ds-carpentry':                'DS Carpentry',
  'davies-property-development': 'Davies Property Development',
  'ir-energy':                   'IR Energy',
  'k-williams-roofing':          'K Williams Roofing',
  'lr-building-roofing':         'L&R Building and Roofing',
  'mj-roofing':                  'M&J Roofing',
};

function getProjectImage(slug: string) {
  const folder = folderMap[slug];

  // Try subfolder first (excluding WhatsApp images)
  if (folder) {
    const match = Object.entries(subfolderImages).find(([path]) => {
      if (!path.includes(`/${folder}/`)) return false;
      const filename = path.split('/').pop() || '';
      return !filename.toLowerCase().startsWith('whatsapp');
    });
    if (match) return match[1].default;
  }

  // Fall back to root-level flat image
  for (const [path, mod] of Object.entries(fallbackImages)) {
    const filename = path.split('/').pop()!.replace(/\.[^.]+$/, '');
    if (filename === slug) return mod.default;
  }

  return null;
}

const serviceLabels: Record<string, string> = {
  'web-design':      'Web Design',
  'web-development': 'Web Development',
  'seo':             'Local SEO',
  'hosting':         'Hosting',
};

const serviceLinks: Record<string, string> = {
  'web-design':      '/services/web-development',
  'web-development': '/services/web-development',
  'seo':             '/services/local-seo-google-ranking',
  'hosting':         '/services/website-hosting-security',
};
---

<BaseLayout
  title="Portfolio | NC Digital"
  description="Case studies from NC Digital — web design and SEO projects for South Wales small businesses."
>

  <section style="padding:5rem 0 3rem; position:relative; overflow:hidden;">
    <HeroOrbs />
    <div class="container site-pad" style="text-align:center; position:relative; z-index:1;">
      <p data-animate="fade-up" class="eyebrow" style="margin-bottom:0.75rem;">Our work</p>
      <h1 data-animate="fade-up" style="margin-bottom:1rem; max-width:620px; margin-left:auto; margin-right:auto;">Real results for South Wales businesses</h1>
      <p data-animate="fade-up" style="color:var(--text-muted); font-size:1.125rem; max-width:560px; line-height:1.7; margin:0 auto;">
        Every project we take on is built to generate leads, rank on Google, and grow with the business.
      </p>
    </div>
  </section>

  <section style="padding:3rem 0 5rem;" id="portfolio-v3">
    <div class="container site-pad">
      <div data-animate="stagger" class="portfolio-grid">
        {projects.map((project) => {
          const slug = project.id.replace('/index.mdoc', '');
          const img = getProjectImage(slug);
          return (
            <div class="portfolio-card">
              <a href={`/portfolio/${slug}`} class="card-image">
                {img ? (
                  <Image
                    src={img}
                    alt={project.data.title}
                    width={600}
                    height={360}
                    class="card-img"
                  />
                ) : (
                  <div class="card-img-placeholder">
                    <span>{project.data.title}</span>
                  </div>
                )}
              </a>
              <div class="card-body">
                <h2 class="card-title">{project.data.title}</h2>
                <p class="card-summary">{project.data.summary}</p>
                <div class="card-tags">
                  {project.data.services.map((s: string) => (
                    <a href={serviceLinks[s] || '/services'} class="card-tag">
                      {serviceLabels[s] || s}
                    </a>
                  ))}
                </div>
                <a href={`/portfolio/${slug}`} class="card-cta">View case study →</a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <style>
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .portfolio-card {
      display: flex;
      flex-direction: column;
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      transition: border-color 0.2s, transform 0.2s;
    }
    .portfolio-card:hover {
      border-color: var(--purple);
      transform: translateY(-2px);
    }

    .card-image {
      display: block;
      width: 100%;
      height: 260px;
      overflow: hidden;
      flex-shrink: 0;
      background: var(--bg-3);
      text-decoration: none;
    }

    .card-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      display: block;
      transition: transform 0.3s ease;
    }
    .portfolio-card:hover .card-img {
      transform: scale(1.03);
    }

    .card-img-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card-img-placeholder span {
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    .card-body {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .card-title {
      font-size: 1.0625rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.5rem;
    }

    .card-summary {
      color: var(--text-muted);
      font-size: 0.875rem;
      line-height: 1.6;
      margin-bottom: 1rem;
      flex: 1;
    }

    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
      margin-bottom: 1rem;
    }

    .card-tag {
      font-size: 0.75rem;
      color: var(--purple);
      background: color-mix(in srgb, var(--purple) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--purple) 30%, transparent);
      border-radius: 4px;
      padding: 0.2rem 0.5rem;
      text-decoration: none;
      transition: background 0.2s, border-color 0.2s;
    }
    .card-tag:hover {
      background: color-mix(in srgb, var(--purple) 20%, transparent);
      border-color: var(--purple);
    }

    .card-body {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .card-cta {
      color: var(--purple);
      font-size: 0.875rem;
      font-weight: 600;
      text-decoration: none;
      margin-top: auto;
    }

    @media (max-width: 900px) {
      .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .portfolio-grid { grid-template-columns: 1fr; }
    }
  </style>

</BaseLayout>
