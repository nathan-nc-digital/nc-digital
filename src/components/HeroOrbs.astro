---
---
<div class="hero-orbs" aria-hidden="true">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
</div>

<style>
  .hero-orbs {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    top: -180px;
    right: -120px;
    background: radial-gradient(circle, rgba(135, 80, 247, 0.45) 0%, rgba(135, 80, 247, 0.15) 40%, transparent 70%);
    animation: orbDrift1 14s ease-in-out infinite alternate;
  }

  .orb-2 {
    width: 420px;
    height: 420px;
    bottom: -120px;
    left: 2%;
    background: radial-gradient(circle, rgba(135, 80, 247, 0.3) 0%, rgba(135, 80, 247, 0.08) 45%, transparent 70%);
    animation: orbDrift2 18s ease-in-out infinite alternate;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    top: 25%;
    left: 35%;
    background: radial-gradient(circle, rgba(167, 120, 255, 0.22) 0%, transparent 65%);
    animation: orbDrift3 11s ease-in-out infinite alternate;
  }

  @keyframes orbDrift1 {
    from { transform: translate(0, 0) scale(1); opacity: 0.9; }
    to   { transform: translate(-80px, 55px) scale(1.15); opacity: 1; }
  }

  @keyframes orbDrift2 {
    from { transform: translate(0, 0) scale(1); opacity: 0.85; }
    to   { transform: translate(100px, -65px) scale(0.88); opacity: 1; }
  }

  @keyframes orbDrift3 {
    from { transform: translate(0, 0) scale(1); opacity: 0.7; }
    to   { transform: translate(-50px, 75px) scale(1.2); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb { animation: none; }
  }
</style>
